# Copy to .env (gitignored) or export in shell before running scripts/sdk.
# Same key as Cursor Dashboard → API Keys; bills to your IDE plan.
CURSOR_API_KEY=key_...

# Model id (default: auto). Override only for fixed benchmark comparisons:
# CURSOR_SDK_MODEL=composer-2.5

# Optional: load .cursor rules/skills like IDE (may add latency; omit for headless smoke)
# CURSOR_SDK_SETTING_SOURCES=project
# CURSOR_SDK_SETTING_SOURCES=project,user
