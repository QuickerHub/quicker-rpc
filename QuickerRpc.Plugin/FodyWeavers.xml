<!--
  Release Quicker plugin (Costura): whitelist plugin-owned Copy Local assemblies.
  Quicker host refs use Private=false in Release (qkref.props); do not embed Quicker install tree.
  If RPC pipe / DI host fails (especially Debug ok, Release plugin not), check this file first.
-->
<Weavers xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="FodyWeavers.xsd">
  <Costura IncludeDebugSymbols="false" CreateTemporaryAssemblies="true">
    <IncludeAssemblies>
      <!-- AgentModel + Contracts: version-suffixed satellite DLLs in package (Quicker AssemblyResolve + hot-update side-by-side). -->
      Google.Protobuf*
      <!-- Microsoft.Extensions 6: DI, Hosting, Logging, Configuration (prefix match) -->
      Microsoft.Extensions*
      Microsoft.Win32*
      Microsoft.NET.StringTools*
      Microsoft.VisualStudio.Threading*
      Microsoft.VisualStudio.Validation*
      System.Text.Json*
      System.Text.Encodings.Web*
      System.IO.Pipelines*
      System.Security.AccessControl*
      System.Security.Principal.Windows*
      System.Threading.Tasks.Dataflow*
      <!-- Not embedded (Quicker install + Quicker.exe.config binding redirects):
           System.Buffers, System.Memory, System.Numerics.Vectors, System.Runtime.CompilerServices.Unsafe,
           System.Diagnostics.DiagnosticSource, System.Threading.Tasks.Extensions, System.ComponentModel.Annotations,
           System.Collections.Immutable, Newtonsoft.Json, Microsoft.Bcl.AsyncInterfaces.
           System.ValueTuple: net472 framework facade only. -->
      StreamJsonRpc*
      MessagePack*
      Nerdbank.Streams*
    </IncludeAssemblies>
  </Costura>
</Weavers>
