<Window x:Class="QuickerRpc.Plugin.UI.QuickerRpcMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickerRpc Monitor"
        Width="920"
        Height="560"
        MinWidth="640"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        ShowInTaskbar="True"
        Activated="OnActivated">
    <Window.Resources>
        <DataTemplate x:Key="ActionIdCellTemplate">
            <TextBlock Tag="ActionIdCopy"
                       Text="{Binding ActionId}"
                       Foreground="#1565C0"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       ToolTip="点击复制 ActionId" />
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Width="72" Margin="0,0,8,0" Click="OnRefreshClick" />
            <Button Content="编辑选中" Width="88" Margin="0,0,8,0" Click="OnEditClick" />
            <Button Content="复制 ID" Width="88" Margin="0,0,8,0" Click="OnCopyIdClick" />
            <TextBlock x:Name="HeaderStatusText"
                       VerticalAlignment="Center"
                       Foreground="#666666"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TabControl x:Name="MainTabs" Grid.Row="1">
            <TabItem Header="qkrpc 虚拟动作页">
                <DataGrid x:Name="AgentGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          PreviewMouseLeftButtonDown="OnGridPreviewMouseLeftButtonDown"
                          PreviewMouseRightButtonDown="OnGridPreviewMouseRightButtonDown"
                          MouseDoubleClick="OnGridDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制动作元数据" Click="OnCopyMetadataClick" />
                            <MenuItem Header="复制 ActionId" Click="OnCopyIdClick" />
                            <Separator />
                            <MenuItem Header="编辑动作" Click="OnEditClick" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="动作页" Binding="{Binding ProfileName}" Width="*" />
                        <DataGridTextColumn Header="最后编辑"
                                            Binding="{Binding LastEditDisplay}"
                                            SortMemberPath="LastEditTimeUtc"
                                            Width="1.4*" />
                        <DataGridTemplateColumn Header="动作 ID"
                                                Width="2*"
                                                SortMemberPath="ActionId"
                                                CellTemplate="{StaticResource ActionIdCellTemplate}" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="最近编辑">
                <DataGrid x:Name="RecentGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          PreviewMouseLeftButtonDown="OnGridPreviewMouseLeftButtonDown"
                          PreviewMouseRightButtonDown="OnGridPreviewMouseRightButtonDown"
                          MouseDoubleClick="OnGridDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制动作元数据" Click="OnCopyMetadataClick" />
                            <MenuItem Header="复制 ActionId" Click="OnCopyIdClick" />
                            <Separator />
                            <MenuItem Header="编辑动作" Click="OnEditClick" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="场景" Binding="{Binding ProfileName}" Width="*" />
                        <DataGridTextColumn Header="ExeFile" Binding="{Binding ExeFile}" Width="*" />
                        <DataGridTextColumn Header="最后编辑"
                                            Binding="{Binding LastEditDisplay}"
                                            SortMemberPath="LastEditTimeUtc"
                                            Width="1.4*" />
                        <DataGridTemplateColumn Header="动作 ID"
                                                Width="2*"
                                                SortMemberPath="ActionId"
                                                CellTemplate="{StaticResource ActionIdCellTemplate}" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="FooterStatusText"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#666666"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
