{
  "stepRunnerKey": "sys:chromecontrol",
  "name": "浏览器控制",
  "description": "与Chrome/Edge/Firefox等浏览器通信，控制网页或浏览器。",
  "controlField": {
    "key": "operation",
    "title": "操作类型",
    "purpose": "操作类型",
    "selection": [
      {
        "key": "OpenUrl",
        "name": "打开网址",
        "visibleInputKeys": [
          "operation",
          "windowId",
          "url",
          "windowInfo",
          "waitComplete",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "tabId",
          "windowId",
          "rawResponse"
        ]
      },
      {
        "key": "WaitTabComplete",
        "name": "等待加载完成",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "ActivateTab",
        "name": "激活标签页",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "url",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "tabId",
          "windowId",
          "groupId",
          "url",
          "title",
          "favicon",
          "rawResponse"
        ]
      },
      {
        "key": "CloseTab",
        "name": "关闭标签页",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "GetTabInfo",
        "name": "获得标签页信息",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "tabId",
          "windowId",
          "groupId",
          "url",
          "title",
          "favicon",
          "browser",
          "extVersion",
          "manifestVersion",
          "envName",
          "rawResponse"
        ]
      },
      {
        "key": "RunScript",
        "name": "对标签页运行脚本 (扩展需开启“允许运行用户脚本”选项)",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "script",
          "timeoutMs",
          "frame",
          "executionWorld",
          "waitManualReturn",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "PickElement",
        "name": "选择元素 (返回CSS选择器)",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "selector",
          "rawResponse"
        ]
      },
      {
        "key": "GetElementInfo",
        "name": "获取元素信息",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "selector",
          "fixSelector",
          "elementInfo",
          "attrName",
          "timeoutMs",
          "frame",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "firstValue",
          "allValues",
          "rawResponse"
        ]
      },
      {
        "key": "UpdateElement",
        "name": "更新元素信息",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "selector",
          "fixSelector",
          "updateElementInfo",
          "attrName",
          "updateElementValue",
          "timeoutMs",
          "frame",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "TriggerEvent",
        "name": "触发事件",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "selector",
          "fixSelector",
          "triggerEventType",
          "timeoutMs",
          "frame",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "Wait",
        "name": "等待网页变化 (MV3版扩展)",
        "visibleInputKeys": [
          "operation",
          "tabId",
          "selector",
          "waitEventType",
          "waitEventParams",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "SetBrowser",
        "name": "浏览器：设置连接的浏览器",
        "visibleInputKeys": [
          "operation",
          "browser",
          "mainProcessId",
          "envName",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "BackgroundScript",
        "name": "浏览器：运行后台脚本",
        "visibleInputKeys": [
          "operation",
          "script",
          "waitComplete",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      },
      {
        "key": "BackgroundCommand",
        "name": "浏览器：运行后台命令 (MV3版扩展)",
        "visibleInputKeys": [
          "operation",
          "command",
          "commandParams",
          "valueFilter",
          "waitComplete",
          "timeoutMs",
          "stopIfFail"
        ],
        "visibleOutputKeys": [
          "isSuccess",
          "rawResponse"
        ]
      }
    ]
