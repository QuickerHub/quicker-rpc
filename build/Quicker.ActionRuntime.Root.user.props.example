<Project>
  <!--
    Copy to: %USERPROFILE%\.config\quicker\Quicker.ActionRuntime.Root.user.props
    Or run Setup-ActionRuntimeSymlink.ps1 from the Quicker repo (QuickerPc/build/).
  -->
  <PropertyGroup>
    <QuickerActionRuntimeRoot>D:\source\repos\quicker\Quicker.ActionRuntime</QuickerActionRuntimeRoot>
  </PropertyGroup>
</Project>
