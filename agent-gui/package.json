{
  "name": "quicker-rpc-agent-gui",
  "version": "0.14.7",
  "private": true,
  "main": "electron/bootstrap.cjs",
  "scripts": {
    "dev": "node ./start.mjs --dev",
    "dev:browser": "node ./start.mjs --dev --open-browser",
    "dev:full": "node ./start.mjs --dev --full-runtimes",
    "dev:webpack": "node ./start.mjs --dev --webpack",
    "build": "next build",
    "start": "node ./start.mjs",
    "lint": "next lint",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:build": "tauri build",
    "tauri:prepare": "node scripts/tauri-prepare.mjs",
    "tauri:verify-bundle": "node scripts/verify-tauri-bundle.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:prepare": "node scripts/electron-prepare.mjs",
    "electron:installer-assets": "node scripts/generate-electron-installer-assets.mjs",
    "electron:icons": "node scripts/generate-app-icons.mjs",
    "electron:icons:sync": "node scripts/generate-electron-installer-assets.mjs --regen",
    "electron:build": "pnpm electron:prepare && electron-builder --win nsis && node scripts/verify-electron-asar.mjs",
    "electron:verify-bundle": "node scripts/verify-desktop-bundle.mjs --resources-dir electron/resources --label electron-staged",
    "electron:check": "node scripts/electron-check.mjs",
    "test:electron-smoke": "pwsh -NoProfile -File ./scripts/Test-QuickerAgentElectronSmoke.ps1 -Action verify",
    "proto:dep": "cd .. && pnpm exec --dir agent-gui buf dep update",
    "proto:gen": "pnpm exec buf generate --template buf.gen.yaml",
    "docs:gen": "node ../scripts/generate-authoring-docs.mjs",
    "docs:check": "node ../scripts/generate-authoring-docs.mjs --check",
    "docs:search": "tsx scripts/demo-docs-search.ts",
    "test:docs-search": "tsx scripts/run-docs-search-tests.ts",
    "test:docs-search:eval": "tsx scripts/eval-docs-search.ts",
    "test:workspace-grep:eval": "tsx scripts/eval-workspace-grep.ts",
    "test:tool-suites": "tsx --test lib/tool-test-suites.test.ts",
    "test:tools": "tsx --test lib/tool-intent-filter.test.ts lib/tool-intent-scenarios.test.ts lib/chat-tool-selection.test.ts lib/qkrpc-merged-tools.test.ts lib/qkrpc-subprogram-tool.test.ts lib/tool-registry.test.ts lib/tool-registry-snapshot.test.ts lib/tool-routing-registry.test.ts lib/tool-test-suites.test.ts lib/tool-test-chat-cleanup.test.ts lib/action-scope.test.ts",
    "test:authoring-benchmark": "tsx --test lib/authoring-benchmark.test.ts lib/empty-chat-prompts.test.ts lib/agent-runtime-eval.test.ts lib/agent-runtime-sequence-eval.test.ts",
    "test:agent-eval": "tsx --test lib/agent-eval/batch-cli.test.ts lib/agent-eval/nightly-cli.test.ts lib/agent-eval/capability-summary.test.ts lib/agent-eval/trace-extract.test.ts lib/agent-eval/trace-rubric.test.ts lib/agent-eval/eval-scenario.test.ts lib/agent-eval/tool-test-ui-runner.test.ts lib/agent-eval/launcher-expect.test.ts lib/agent-eval/chat-stream.test.ts lib/agent-eval/eval-chat-error.test.ts lib/agent-harness/static-shell-baseline.test.ts lib/agent-harness/model-tool-definitions.test.ts lib/agent-harness/harness-preview.test.ts lib/agent-harness/tool-execution-context.test.ts",
    "measure:static-shell": "tsx scripts/measure-static-shell-tokens.ts",
    "test:action-trace-location": "tsx --test lib/action-trace-data-json-location.test.ts lib/action-trace-failure-location.integration.test.ts",
    "agent-eval": "tsx scripts/run-agent-eval.ts",
    "agent-eval:ui": "tsx scripts/run-agent-eval-ui.ts",
    "agent-eval:batch": "tsx scripts/run-agent-eval-batch.ts",
    "agent-eval:compare": "tsx scripts/compare-agent-eval-runners.ts",
    "agent-eval:nightly": "tsx scripts/run-agent-eval-nightly.ts",
    "agent-session": "tsx scripts/run-agent-session-analyze.ts",
    "agent-autopilot": "tsx scripts/run-agent-autopilot.ts",
    "agent-autopilot:batch": "tsx scripts/run-agent-autopilot-batch.ts",
    "test:agent-session": "tsx --test lib/agent-session-analysis/analyze.test.ts lib/agent-session-analysis/match-task.test.ts",
    "test:context-compression": "tsx --test lib/context-compression.test.ts lib/context-compression.integration.test.ts lib/context-compression-reactive.test.ts lib/context-compression-metadata-display.test.ts lib/context-compaction-reinject.test.ts lib/context-step-microcompact.test.ts lib/context-token-estimate.test.ts lib/context-api-rounds.test.ts lib/context-microcompact.test.ts lib/tool-result-agent-view.test.ts lib/tool-test-agent-view-scenarios.test.ts lib/action-project-workflow.test.ts lib/action-project-roundtrip.test.ts lib/action-project-file.test.ts lib/workspace-fs.test.ts lib/action-editor/programWire.test.ts",
    "test:step-editor": "tsx --test lib/action-editor/data/step-runners-ui-catalog.test.ts lib/action-editor/steps/**/*.test.ts lib/action-editor/steps/stepRunnerKeyResolve.test.ts lib/action-editor/subprograms/globalSubProgramCatalog.test.ts lib/action-editor/variables/variableParamInfoHelpers.test.ts lib/action-editor/programWire.test.ts",
    "test:launcher": "tsx --test lib/launcher/*.test.ts",
    "preflight:fast": "node scripts/preflight-release-gate.mjs",
    "preflight:build": "pwsh -NoProfile -File ../publish/Preflight-QuickerAgentBuild.ps1",
    "test:voice-input": "tsx --test lib/voice-input/voice-input-plugin-status.test.ts",
    "test:voice-chat": "tsx --test lib/voice-chat/sentence-chunker.test.ts",
    "test:voice-install-trigger": "node scripts/test-voice-plugin-auto-install.mjs trigger-check",
    "test:app-update": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action full",
    "test:app-update:unit": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action unit",
    "test:app-update:prepare": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action prepare -SkipBuild",
    "test:app-update:installed": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action full -SkipBuild -UseInstalled -RemoteVersion 0.11.5 -ExitInstall",
    "repair:quicker-agent": "pwsh -NoProfile -File scripts/Repair-QuickerAgentResources.ps1",
    "voice:install-test": "node scripts/test-voice-plugin-auto-install.mjs status",
    "voice:dev-server": "uv run --directory ../voice-asr-runtime quicker-voice-runtime",
    "voice:download-model": "uv run --directory ../voice-asr-runtime download-asr-model",
    "browser:dev-server": "node browser-runtime/server.mjs",
    "terminal:dev-server": "node terminal-runtime/server.mjs",
    "browser:install": "playwright install msedge",
    "probe:llm-configs": "tsx scripts/probe-llm-configs.ts",
    "probe:publish-config": "tsx scripts/probe-llm-configs.ts -- --source publish --method full",
    "dev:smoke": "node scripts/frontend-smoke.mjs",
    "dev:heal-loop": "node scripts/dev-heal-loop.mjs",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "prebuild": "pnpm docs:gen"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/react": "^3.0.195",
    "@bufbuild/protobuf": "^2.2.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@iconify/icons-mdi": "^1.2.48",
    "@iconify/react": "^6.0.2",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "minisearch": "^7.2.0",
    "next": "^15.3.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "ws": "^8.18.3",
    "zod": "^3.24.0"
  },
  "build": {
    "appId": "ai.quicker.agent.electron",
    "afterPack": "scripts/patch-electron-exe-icon.mjs",
    "productName": "QuickerAgent",
    "directories": {
      "app": "electron/shell-app",
      "output": "electron/dist",
      "buildResources": "electron/build"
    },
    "files": [
      "electron/**/*.mjs",
      "electron/**/*.cjs",
      "browser-runtime/**/*.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/resources",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src-tauri/icons/icon.ico",
        "to": "app-icon.ico"
      }
    ],
    "asar": true,
    "electronVersion": "33.4.11",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src-tauri/icons/icon.ico",
      "signAndEditExecutable": false,
      "executableName": "quicker-agent"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "quicker-agent-${version}-x64-setup.${ext}",
      "include": "installer.nsh",
      "installerIcon": "installerIcon.ico",
      "installerHeaderIcon": "installerIcon.ico",
      "uninstallerIcon": "installerIcon.ico",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "displayLanguageSelector": false,
      "shortcutName": "QuickerAgent",
      "menuCategory": "QuickerAgent",
      "uninstallDisplayName": "QuickerAgent",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://s3.bitiful.net/quicker-pkgs/quicker-rpc/quicker-agent/"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "better-sqlite3",
      "electron-binary",
      "node-pty"
    ]
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.47.2",
    "@bufbuild/protoc-gen-es": "^2.2.3",
    "@tauri-apps/cli": "^2.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "electron-binary": "npm:electron@33.4.11",
    "electron-builder": "^25.1.8",
    "rcedit": "4.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.0"
  }
}
