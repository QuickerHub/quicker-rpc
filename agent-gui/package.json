{
  "name": "quicker-rpc-agent-gui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./start.mjs --dev",
    "dev:browser": "node ./start.mjs --dev --open-browser",
    "dev:full": "node ./start.mjs --dev --full-runtimes",
    "dev:webpack": "node ./start.mjs --dev --webpack",
    "build": "next build",
    "start": "node ./start.mjs",
    "lint": "next lint",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:build": "tauri build",
    "tauri:prepare": "node scripts/tauri-prepare.mjs",
    "tauri:verify-bundle": "node scripts/verify-tauri-bundle.mjs",
    "proto:dep": "cd .. && pnpm exec --dir agent-gui buf dep update",
    "proto:gen": "pnpm exec buf generate --template buf.gen.yaml",
    "docs:gen": "node ../scripts/generate-authoring-docs.mjs",
    "docs:check": "node ../scripts/generate-authoring-docs.mjs --check",
    "docs:search": "tsx scripts/demo-docs-search.ts",
    "test:docs-search": "tsx scripts/run-docs-search-tests.ts",
    "test:docs-search:eval": "tsx scripts/eval-docs-search.ts",
    "test:workspace-grep:eval": "tsx scripts/eval-workspace-grep.ts",
    "test:tool-suites": "tsx --test lib/tool-test-suites.test.ts",
    "test:context-compression": "tsx --test lib/context-compression.test.ts lib/context-compression.integration.test.ts lib/action-project-workflow.test.ts lib/action-project-roundtrip.test.ts lib/action-project-file.test.ts lib/workspace-fs.test.ts lib/action-editor/programWire.test.ts",
    "test:step-editor": "tsx --test lib/action-editor/steps/**/*.test.ts lib/action-editor/steps/stepRunnerKeyResolve.test.ts lib/action-editor/subprograms/globalSubProgramCatalog.test.ts lib/action-editor/variables/variableParamInfoHelpers.test.ts lib/action-editor/programWire.test.ts",
    "test:launcher": "tsx --test lib/launcher/*.test.ts",
    "preflight:fast": "node scripts/preflight-release-gate.mjs",
    "preflight:build": "pwsh -NoProfile -File ../publish/Preflight-QuickerAgentBuild.ps1",
    "test:voice-input": "tsx --test lib/voice-input/voice-input-plugin-status.test.ts",
    "test:voice-chat": "tsx --test lib/voice-chat/sentence-chunker.test.ts",
    "test:voice-install-trigger": "node scripts/test-voice-plugin-auto-install.mjs trigger-check",
    "test:app-update": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action full",
    "test:app-update:unit": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action unit",
    "test:app-update:prepare": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action prepare -SkipBuild",
    "test:app-update:installed": "pwsh -NoProfile -File scripts/Test-AppUpdateApply.ps1 -Action full -SkipBuild -UseInstalled -RemoteVersion 0.11.5 -ExitInstall",
    "repair:quicker-agent": "pwsh -NoProfile -File scripts/Repair-QuickerAgentResources.ps1",
    "voice:install-test": "node scripts/test-voice-plugin-auto-install.mjs status",
    "voice:dev-server": "uv run --directory ../voice-asr-runtime quicker-voice-runtime",
    "voice:download-model": "uv run --directory ../voice-asr-runtime download-asr-model",
    "browser:dev-server": "node browser-runtime/server.mjs",
    "browser:install": "playwright install msedge",
    "probe:llm-configs": "tsx scripts/probe-llm-configs.ts",
    "probe:publish-config": "tsx scripts/probe-llm-configs.ts -- --source publish --method full",
    "dev:smoke": "node scripts/frontend-smoke.mjs",
    "dev:heal-loop": "node scripts/dev-heal-loop.mjs",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "prebuild": "pnpm docs:gen"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/react": "^3.0.195",
    "@bufbuild/protobuf": "^2.2.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@iconify/icons-mdi": "^1.2.48",
    "@iconify/react": "^6.0.2",
    "@lezer/highlight": "^1.2.3",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@uiw/react-codemirror": "^4.25.10",
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "minisearch": "^7.2.0",
    "monaco-editor": "^0.55.1",
    "next": "^15.3.0",
    "playwright": "^1.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "ws": "^8.18.3",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.47.2",
    "@bufbuild/protoc-gen-es": "^2.2.3",
    "@tauri-apps/cli": "^2.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.0"
  }
}
