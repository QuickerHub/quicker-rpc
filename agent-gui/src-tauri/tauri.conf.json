{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickerAgent",
  "version": "0.9.0",
  "identifier": "ai.quicker.agent",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "pnpm build && node scripts/tauri-prepare.mjs",
    "frontendDist": "../src-tauri/placeholder"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuickerAgent",
        "width": 1280,
        "height": 800,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
