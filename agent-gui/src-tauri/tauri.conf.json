{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickerAgent",
  "version": "0.11.5",
  "identifier": "ai.quicker.agent",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "",
    "frontendDist": "../src-tauri/placeholder"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuickerAgent",
        "width": 1280,
        "height": 800,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "launcher",
        "title": "QuickerAgent 快速输入",
        "url": "/launcher",
        "width": 680,
        "height": 520,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwOTBBMTUzRTgwMDA2RDkKUldUWkJnRG9VNkdRSUFvMDZ3ZUx0VWk4UHg5MDZRV2loUkxEbEcrQ3RNdzNTNHZJUkpIdHdKZmwK",
      "endpoints": [
        "https://s3.bitiful.net/quicker-pkgs/quicker-rpc/quicker-agent/latest.json",
        "https://github.com/QuickerHub/quicker-rpc/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

