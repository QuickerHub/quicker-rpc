{

  "$schema": "./agent-gui-scenarios.schema.json",

  "version": 1,

  "title": "QuickerAgent agent-gui stack scenarios",

  "description": "Scenarios for production /api/chat path. Launcher cases assert user outcome (settings open / action resolve), not a fixed tool chain.",

  "scenarios": [

    {

      "id": "launcher-open-hotkeys",

      "category": "launcher",

      "label": "打开功能快捷键",

      "userPrompt": "请帮我打开功能快捷键设置页面",

      "chatMode": "launcher",

      "readOnly": true,

      "expect": {

        "mustNotCall": ["workspace_program", "Write", "StrReplace", "qkrpc_step_runner_search"],

        "launcher": {

          "intent": "open-settings",

          "settingsOpen": { "page": "FunctionHotkeys" }

        }

      }

    },

    {

      "id": "launcher-open-recycle-bin",

      "category": "launcher",

      "label": "动作回收站",

      "userPrompt": "请帮我打开 Quicker 的动作回收站",

      "chatMode": "launcher",

      "readOnly": true,

      "expect": {

        "mustNotCall": ["workspace_program", "Write", "StrReplace"],

        "launcher": {

          "intent": "open-settings",

          "settingsOpen": { "page": "recycle-bin" }

        }

      }

    },

    {

      "id": "launcher-open-search",

      "category": "launcher",

      "label": "Quicker 搜索",

      "userPrompt": "请打开 Quicker 的全局搜索功能",

      "chatMode": "launcher",

      "readOnly": true,

      "expect": {

        "mustNotCall": ["workspace_program", "Write", "StrReplace"],

        "launcher": {

          "intent": "open-search",

          "settingsOpen": { "intent": "open-search" }

        }

      }

    },

    {

      "id": "launcher-run-vague",

      "category": "launcher",

      "label": "运行动作（模糊）",

      "userPrompt": "请帮我运行一个和剪贴板相关的动作",

      "chatMode": "launcher",

      "readOnly": true,

      "expect": {

        "mustNotCall": ["workspace_program", "qkrpc_step_runner_get", "Write", "StrReplace"],

        "launcher": {

          "intent": "run-action"

        }

      }

    },

    {

      "id": "workspace-structure-readonly",

      "category": "workspace",

      "label": "只读分析工作区",

      "userPrompt": "分析这个项目的代码结构，先不要修改任何文件",

      "chatMode": "agent",

      "readOnly": true,

      "expect": {

        "mustCallAny": ["Grep", "Read"],

        "mustNotCall": ["Write", "workspace_program", "StrReplace"]

      }

    },

    {

      "id": "discover-docs-via-agent",

      "category": "agent-stack",

      "label": "文档检索工作流",

      "userPrompt": "从零新建一个 Quicker 动作并保存，大致要经过哪些阶段？用 5 条以内的要点说明即可。",

      "chatMode": "agent",

      "readOnly": true,

      "expect": {

        "mustCall": ["docs"],

        "mustNotCall": ["workspace_program"]

      }

    },

    {

      "id": "slash-list-actions",

      "category": "agent-defs",

      "label": "斜杠命令 list-actions",

      "userPrompt": "/list-actions 5",

      "chatMode": "agent",

      "readOnly": true,

      "fixture": "eval-workspace",

      "expect": {

        "mustCall": ["qkrpc_action_query"],

        "mustNotCall": ["workspace_program", "Write"]

      }

    },

    {

      "id": "slash-author-bundled",

      "category": "agent-defs",

      "label": "bundled 斜杠 /author",

      "userPrompt": "/author 列出当前工作区动作并说明下一步如何创建新动作（先不要 patch）",

      "chatMode": "agent",

      "readOnly": true,

      "expect": {

        "mustCallAny": ["qkrpc_action_query", "docs", "ask_question", "workspace_program"],

        "mustNotCall": ["Write", "Shell"]

      }

    },

    {

      "id": "slash-verify-bundled",

      "category": "agent-defs",

      "label": "bundled 斜杠 /verify",

      "userPrompt": "/verify 当前工作区第一个动作",

      "chatMode": "agent",

      "readOnly": true,

      "expect": {

        "mustCallAny": ["workspace_program", "qkrpc_action_query", "docs"],

        "mustNotCall": ["Write", "Shell"]

      }

    },

    {

      "id": "task-readonly-explore",

      "category": "agent-defs",

      "label": "task 子代理 readonly-explore",

      "userPrompt": "请委派 readonly-explore 子代理：在工作区根目录查找 README 文件并返回路径列表，不要修改任何文件。",

      "chatMode": "agent",

      "readOnly": true,

      "fixture": "eval-workspace",

      "expect": {

        "mustCall": ["task"],

        "mustNotCall": ["workspace_program", "Write"]

      }

    },

    {

      "id": "task-step-runner-lookup",

      "category": "agent-defs",

      "label": "task 子代理 step-runner-lookup",

      "userPrompt": "请委派 step-runner-lookup 子代理：查找用于单变量赋值的 step-runner key 和 inputParams，不要 patch。",

      "chatMode": "agent",

      "readOnly": true,

      "expect": {

        "mustCall": ["task"],

        "mustNotCall": ["workspace_program", "Write"]

      }

    },

    {

      "id": "task-action-library-search",

      "category": "agent-defs",

      "label": "task 子代理 action-library-search",

      "userPrompt": "请委派 action-library-search 子代理：在动作库搜索「HTTP JSON」相关分享动作并总结可借鉴的模式，只读不要 patch。",

      "chatMode": "agent",

      "readOnly": true,

      "expect": {

        "mustCall": ["task"],

        "mustNotCall": ["workspace_program", "Write"]

      }

    }

  ]

}


