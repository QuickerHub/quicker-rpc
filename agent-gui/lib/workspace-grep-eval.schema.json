{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace grep eval cases",
  "type": "object",
  "required": ["version", "cases"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "cases": {
      "type": "array",
      "items": { "$ref": "#/definitions/case" }
    }
  },
  "definitions": {
    "match": {
      "type": "object",
      "required": ["path", "line"],
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    },
    "expect": {
      "type": "object",
      "properties": {
        "minMatches": { "type": "integer", "minimum": 0 },
        "maxMatches": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matches": {
          "type": "array",
          "items": { "$ref": "#/definitions/match" }
        }
      }
    },
    "case": {
      "type": "object",
      "required": ["id", "category", "files", "path", "query", "expect"],
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "files": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "path": { "type": "string" },
        "query": { "type": "string" },
        "options": {
          "type": "object",
          "properties": {
            "maxMatches": { "type": "integer" },
            "caseInsensitive": { "type": "boolean" },
            "literal": { "type": "boolean" }
          }
        },
        "expect": { "$ref": "#/definitions/expect" },
        "knownIssue": { "type": "string" }
      }
    }
  }
}
