{
  "help": {
    "cli": "qkrpc help --json",
    "agent": null
  },
  "docs.get": {
    "cli": "qkrpc guide get --topic {{topic}} --json",
    "agent": "docs({ action: \"get\", topic: \"{{topic}}\" })",
    "defaults": {
      "topic": "overview"
    }
  },
  "docs.search": {
    "cli": "qkrpc guide search --query {{query}} --json",
    "agent": "docs({ action: \"search\", query: \"{{query}}\" })",
    "defaults": {
      "query": "keyword"
    }
  },
  "docs.index": {
    "cli": "qkrpc guide search [--limit 50] --json",
    "agent": "docs({ action: \"index\" })"
  },
  "settings.pages": {
    "cli": "qkrpc settings pages --json",
    "agent": "quicker_settings({ action: \"pages\" })"
  },
  "settings.open": {
    "cli": "qkrpc settings open --page {{page}} [--exe {{exe}}] --json",
    "agent": "quicker_settings({ action: \"open\", page: \"{{page}}\", exe?: \"{{exe}}\" })",
    "defaults": {
      "page": "recycle-bin",
      "exe": "_global"
    }
  },
  "settings.search": {
    "cli": "qkrpc settings search --query {{query}} [--limit {{limit}}] --json",
    "agent": "quicker_settings({ action: \"search\", query: \"{{query}}\", limit?: {{limit}} })",
    "defaults": {
      "query": "keyword",
      "limit": "30"
    }
  },
  "settings.get": {
    "cli": "qkrpc settings get --key {{key}} --json",
    "agent": "quicker_settings({ action: \"get\", key: \"{{key}}\" })",
    "defaults": {
      "key": "userSettings:EnableCircleMenu"
    }
  },
  "settings.set": {
    "cli": "qkrpc settings set --key {{key}} --value {{value}} --json",
    "agent": "quicker_settings({ action: \"set\", key: \"{{key}}\", value: \"{{value}}\" })",
    "defaults": {
      "key": "userSettings:EnableCircleMenu",
      "value": "true"
    }
  },
  "settings.apply": {
    "cli": "qkrpc settings apply --changes-file {{file}} --json",
    "agent": "quicker_settings({ action: \"apply\", patch: { ... } })",
    "defaults": {
      "file": "settings-patch.json"
    }
  },
  "action.create": {
    "cli": "qkrpc action create --title \"{{title}}\" [--icon {{icon}}] --json",
    "agent": "qkrpc_action_create({ info: { title: \"{{title}}\", description?: \"…\", icon?: \"{{icon}}\" } })",
    "defaults": {
      "title": "MyAction",
      "icon": "fa:Light_*"
    }
  },
  "action.list": {
    "cli": "qkrpc action list --query \"{{query}}\" [--scope {{scope}}] --json",
    "agent": "qkrpc_action_list({ query: \"{{query}}\", scope?: \"{{scope}}\" })",
    "defaults": {
      "query": "keyword",
      "scope": "agent"
    }
  },
  "action.search": {
    "cli": "qkrpc action search --query \"{{query}}\" [--scope {{scope}}] --json",
    "agent": "qkrpc_action_search({ query: \"{{query}}\", scope?: \"{{scope}}\" })",
    "defaults": {
      "query": "keyword",
      "scope": "agent"
    }
  },
  "action.get.structure": {
    "cli": "qkrpc action get --id {{id}} --return-mode structure --json",
    "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"structure\" })",
    "defaults": {
      "id": "<guid>"
    }
  },
  "action.get.full": {
    "cli": "qkrpc action get --id {{id}} --return-mode full --json",
    "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"full\" })",
    "defaults": {
      "id": "<guid>"
    }
  },
  "action.get.metadata": {
    "cli": "qkrpc action get --id {{id}} --return-mode metadata --json",
    "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"metadata\" })",
    "defaults": {
      "id": "<guid>"
    }
  },
  "action.set-metadata": {
    "cli": "qkrpc action set-metadata --id {{id}} --icon {{icon}} --expected-edit-version {{N}} --json",
    "agent": "qkrpc_action_set_metadata({ id: \"{{id}}\", icon: \"{{icon}}\", expectedEditVersion: {{N}} })",
    "defaults": {
      "id": "<guid>",
      "icon": "fa:Light_<Name>",
      "N": "<N>"
    }
  },
  "action.publish": {
    "cli": "qkrpc action publish --id {{id}} [--title \"{{title}}\"] [--description \"{{description}}\"] [--changelog \"{{changelog}}\"] [--html-file \"{{htmlFile}}\"] [--tags {{tags}}] [--private] [--json]",
    "agent": "qkrpc_action_publish({ id: \"{{id}}\", title?: \"{{title}}\", description?: \"{{description}}\", html?: \"{{html}}\", tags?: \"{{tags}}\", changelog?: \"{{changelog}}\", isPublic?: true })",
    "defaults": {
      "id": "<guid>",
      "title": "My Action",
      "description": "One-line summary",
      "changelog": "v1.1: fix timeout",
      "html": "<p>Intro</p>",
      "htmlFile": "<path>",
      "tags": "tag1,tag2"
    }
  },
  "action.shared-info.get": {
    "cli": "qkrpc action shared-info-get --id {{id}} [--json]",
    "agent": null,
    "agentNote": "（内置自动化 / 发布脚本；读取 getquicker 动作说明 Detail HTML；Agent 禁止自主调用）",
    "defaults": {
      "id": "<sharedId>"
    }
  },
  "action.shared-info.set": {
    "cli": "qkrpc action shared-info-set --id {{id}} --html-file {{file}} [--json]",
    "agent": null,
    "agentNote": "（内置自动化 / publish/Sync-QuickerAgentActionDoc.ps1；写入 getquicker 动作说明 Detail HTML；Agent 禁止自主调用）",
    "defaults": {
      "id": "<sharedId>",
      "file": "info.html"
    }
  },
  "action.update": {
    "cli": "qkrpc action update --id {{id}} --changelog \"{{changelog}}\" [--json]",
    "agent": "qkrpc_action_publish({ id: \"{{id}}\", changelog: \"{{changelog}}\" })",
    "defaults": {
      "id": "<guid>",
      "changelog": "v1.1: fix …"
    }
  },
  "action.debug": {
    "cli": "qkrpc action run --id {{id}} --trace --json",
    "agent": "qkrpc_action_debug({ id: \"{{id}}\" })",
    "defaults": {
      "id": "<guid>"
    }
  },
  "action.patch": {
    "cli": "qkrpc action patch --id {{id}} --patch-file patch.json --expected-edit-version {{N}} --json",
    "agent": "qkrpc_action_patch({ id: \"{{id}}\" })",
    "agentNote": "（从 .quicker 项目 apply；勿传 patch 对象。可选 expectedEditVersion / force — 见工具说明。）",
    "defaults": {
      "id": "<guid>",
      "N": "<N>"
    }
  },
  "action.patch.stdin": {
    "cli": "Get-Content patch.json -Raw | qkrpc action patch --id {{id}} --patch-file - --json",
    "agent": null,
    "defaults": {
      "id": "<guid>"
    }
  },
  "action.export": {
    "cli": "qkrpc action export --id {{id}} --dir {{dir}} --json",
    "agent": "qkrpc_action_export({ id: \"{{id}}\", dir: \"{{dir}}\" })",
    "agentNote": "（legacy；优先 qkrpc_action_extract）",
    "defaults": {
      "id": "<guid>",
      "dir": ".quicker/actions/<guid>"
    }
  },
  "action.extract": {
    "cli": "qkrpc action extract --id {{id}} [--dir {{dir}}] [--min-lines 4] --json",
    "agent": null,
    "agentNote": "（agent-gui 内部：qkrpc_action_get 自动 extract，勿手动调用）",
    "defaults": {
      "id": "<guid>",
      "dir": ".quicker/actions/<guid>"
    }
  },
  "action.apply": {
    "cli": "qkrpc action apply --id {{id}} [--dir {{dir}}] [--expected-edit-version {{N}}] [--force] --json",
    "agent": null,
    "agentNote": "（agent-gui 内部：qkrpc_action_patch 自动 apply，勿手动调用）",
    "defaults": {
      "id": "<guid>",
      "dir": ".quicker/actions/<guid>",
      "N": "<N>"
    }
  },
  "action.validate": {
    "cli": "qkrpc action validate [--id {{id}}] [--dir {{dir}}] --json",
    "agentNote": "由 qkrpc_action_apply 内部调用；无需 agent 单独执行",
    "defaults": {
      "id": "<guid>",
      "dir": ".quicker/actions/<guid>"
    }
  },
  "action.import": {
    "cli": "qkrpc action import --dir {{dir}} [--expected-edit-version {{N}}] [--force] --json",
    "agent": "qkrpc_action_import({ dir: \"{{dir}}\", expectedEditVersion: {{N}} })",
    "agentNote": "（legacy；优先 qkrpc_action_apply）",
    "defaults": {
      "dir": ".quicker/actions/<guid>",
      "N": "N"
    }
  },
  "subprogram.create": {
    "cli": "qkrpc subprogram create --name \"{{name}}\" [--icon {{icon}}] --json",
    "agent": null,
    "agentNote": "（agent-ui 暂无 subprogram create；终端用 qkrpc CLI）",
    "defaults": {
      "name": "MySub",
      "icon": "fa:Light_*"
    }
  },
  "subprogram.get": {
    "cli": "qkrpc subprogram get --id {{id}} --return-mode full --json",
    "agent": "qkrpc_subprogram_get({ id: \"{{id}}\", returnMode: \"full\" })",
    "defaults": {
      "id": "<id|name>"
    }
  },
  "subprogram.patch": {
    "cli": "qkrpc subprogram patch --id {{id}} --patch-file patch.json --expected-edit-version {{N}} --json",
    "agent": null,
    "agentNote": "（agent-ui 暂无 subprogram patch；终端用 qkrpc CLI）",
    "defaults": {
      "id": "<id>",
      "N": "<N>"
    }
  },
  "subprogram.export": {
    "cli": "qkrpc subprogram export --id {{id}} --dir {{dir}} --json",
    "agent": null,
    "agentNote": "（agent-ui 暂无；终端用 qkrpc CLI）",
    "defaults": {
      "id": "<nameOrId>",
      "dir": ".quicker/subprograms/my-sub"
    }
  },
  "subprogram.import": {
    "cli": "qkrpc subprogram import --dir {{dir}} --json",
    "agent": null,
    "agentNote": "（agent-ui 暂无；终端用 qkrpc CLI）",
    "defaults": {
      "dir": ".quicker/subprograms/my-sub"
    }
  },
  "step-runner.search": {
    "cli": "qkrpc step-runner search --query \"{{query}}\" --json",
    "agent": "qkrpc_step_runner_search({ query: \"{{query}}\" })",
    "defaults": {
      "query": "clipboard|sys:*clip*"
    }
  },
  "step-runner.search.expr": {
    "cli": "qkrpc step-runner search --query \"expression|evalexpression|sys:evalexpression\" --json",
    "agent": "qkrpc_step_runner_search({ query: \"expression|evalexpression|sys:evalexpression\" })"
  },
  "step-runner.get": {
    "cli": "qkrpc step-runner get --key {{key}} --json",
    "agent": "qkrpc_step_runner_get({ key: \"{{key}}\" })",
    "defaults": {
      "key": "sys:MsgBox"
    }
  },
  "step-runner.get-ui": {
    "cli": "qkrpc step-runner get-ui --key {{key}} --json",
    "defaults": {
      "key": "sys:MsgBox"
    }
  },
  "step-runner.get.control": {
    "cli": "qkrpc step-runner get --key {{key}} --control-field {{control}} --json",
    "agent": "qkrpc_step_runner_get({ key: \"{{key}}\", controlField: \"{{control}}\" })",
    "defaults": {
      "key": "sys:windowOperations",
      "control": "move_ex"
    }
  },
  "step-runner.get.subprogram": {
    "cli": "qkrpc step-runner get --key sys:subprogram --json",
    "agent": "qkrpc_step_runner_get({ key: \"sys:subprogram\" })"
  },
  "step-runner.get.evalexpression": {
    "cli": "qkrpc step-runner get --key sys:evalexpression --json",
    "agent": "qkrpc_step_runner_get({ key: \"sys:evalexpression\" })"
  },
  "fa.search": {
    "cli": "qkrpc fa search [--query {{query}}] --json",
    "agent": "qkrpc_fa_search({ query?: \"{{query}}\" })",
    "defaults": {
      "query": "keyword"
    }
  },
  "form.validate": {
    "cli": "qkrpc form validate --file {{file}} --json",
    "agent": "qkrpc_form_validate({ file: \"{{file}}\" })",
    "defaults": {
      "file": "form.json"
    }
  },
  "form.build": {
    "cli": "qkrpc form build --file {{file}} --json",
    "agent": "qkrpc_form_build({ file: \"{{file}}\" })",
    "defaults": {
      "file": "form.json"
    }
  },
  "action.move": {
    "cli": "qkrpc action move --id {{id}} --profile {{profile}} [--row {{row}} --col {{col}}] [--swap] --json",
    "agent": "qkrpc_action_move({ id: \"{{id}}\", profile: \"{{profile}}\", row?: {{row}}, col?: {{col}}, swap?: true })",
    "defaults": {
      "id": "<guid>",
      "profile": "_global",
      "row": "0",
      "col": "0"
    }
  },
  "profile.create": {
    "cli": "qkrpc profile create --scope global [--count {{count}}] [--after-first] --json",
    "agent": "qkrpc_profile_create({ count?: {{count}}, afterFirst: true })",
    "defaults": {
      "count": "1"
    }
  },
  "profile.delete": {
    "cli": "qkrpc profile delete --id {{id}} [--ids {{profileIds}}] --json",
    "agent": "qkrpc_profile_delete({ profileId?: \"{{id}}\", profileIds?: [\"{{profileIds}}\"] })",
    "defaults": {
      "id": "<profileId>",
      "profileIds": "<guid1>,<guid2>"
    }
  },
  "profile.reorder": {
    "cli": "qkrpc profile reorder --scope global --after-first --ids {{profileIds}} --json",
    "agent": "qkrpc_profile_reorder({ profileIds: [\"{{profileIds}}\"] })",
    "defaults": {
      "profileIds": "<guid1>,<guid2>"
    }
  },
  "process.ensure": {
    "cli": "qkrpc process ensure --exe {{exe}} --name \"{{name}}\" --profile-prefix \"{{profilePrefix}}\" [--collect-subprogram {{collectSubProgram}} --move-actions [--move-any]] --json",
    "agent": "qkrpc_process_ensure({ exeFile: \"{{exe}}\", displayName: \"{{name}}\", profileNamePrefix: \"{{profilePrefix}}\", collectSubProgramName?: \"{{collectSubProgram}}\", moveActions?: true, moveAny?: true })",
    "defaults": {
      "exe": "_my_app",
      "name": "My App",
      "profilePrefix": "@MyApp ",
      "collectSubProgram": "MySub"
    }
  },
  "action.search.uses": {
    "cli": "qkrpc action search --query \"uses:{{subProgram}}\" [--scope {{scope}}] --json",
    "agent": "qkrpc_action_search({ query: \"uses:{{subProgram}}\", scope?: \"{{scope}}\" })",
    "defaults": {
      "subProgram": "SubName",
      "scope": "global"
    }
  },
  "trigger.events": {
    "cli": "qkrpc trigger events [--event {{eventType}}] --json",
    "agent": "quicker_trigger({ action: \"events\", eventType?: \"{{eventType}}\" })",
    "defaults": {
      "eventType": "BrowserUrlChanged"
    }
  },
  "trigger.list": {
    "cli": "qkrpc trigger list [--query {{query}}] [--event {{eventType}}] --json",
    "agent": "quicker_trigger({ action: \"list\", query?: \"{{query}}\", eventType?: \"{{eventType}}\" })",
    "defaults": {
      "query": "keyword",
      "eventType": "BrowserUrlChanged"
    }
  },
  "trigger.add": {
    "cli": "qkrpc trigger add --event {{eventType}} --action {{action}} --params '{{params}}' [--note {{note}}] [--filter {{filter}}] [--delay {{delayMs}}] [--json]",
    "agent": "quicker_trigger({ action: \"add\", eventType: \"{{eventType}}\", actionIdOrName: \"{{action}}\", params: {{params}}, note?: \"{{note}}\", filter?: \"{{filter}}\", delayMs?: {{delayMs}} })",
    "defaults": {
      "eventType": "BrowserUrlChanged",
      "action": "<guid>",
      "params": "{\"UrlPattern\":\"https://github.com\",\"OnlyActiveTab\":true}",
      "note": "auto-run on GitHub",
      "filter": "",
      "delayMs": "0"
    }
  },
  "trigger.update": {
    "cli": "qkrpc trigger update --id {{id}} [--params '{{params}}'] [--enabled|--disabled] [--note {{note}}] --json",
    "agent": "quicker_trigger({ action: \"update\", id: \"{{id}}\", params?: {{params}}, enabled?: true, note?: \"{{note}}\" })",
    "defaults": {
      "id": "<guid>",
      "params": "{\"OnlyActiveTab\":true}",
      "note": ""
    }
  },
  "trigger.delete": {
    "cli": "qkrpc trigger delete --id {{id}} --json",
    "agent": "quicker_trigger({ action: \"delete\", id: \"{{id}}\" })",
    "defaults": {
      "id": "<guid>"
    }
  },
  "trigger.enable": {
    "cli": "qkrpc trigger enable --id {{id}} --json",
    "agent": "quicker_trigger({ action: \"enable\", id: \"{{id}}\" })",
    "defaults": {
      "id": "<guid>"
    }
  },
  "trigger.disable": {
    "cli": "qkrpc trigger disable --id {{id}} --json",
    "agent": "quicker_trigger({ action: \"disable\", id: \"{{id}}\" })",
    "defaults": {
      "id": "<guid>"
    }
  }
}
