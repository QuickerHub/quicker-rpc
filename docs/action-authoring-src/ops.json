{
  "phrases": {
    "authoring.title": {
      "cli": "qkrpc 写动作流程（Agent 必读）",
      "agent": "写动作流程（Agent 必读）"
    },
    "product.intro": {
      "cli": "无头编辑 XAction：**`qkrpc`** + QuickerRpc 插件。命令表：{{@ help}}。流程：**`authoring-workflow`**、**`overview`**。",
      "agent": "无头编辑 XAction：**agent-ui 工具** + QuickerRpc 插件。流程专题见 **`docs_index`**；参数/字段以各工具 description 为准，勿在回复中粘贴指南全文。"
    },
    "help.detail": {
      "cli": "命令细节：`qkrpc help --json`",
      "agent": "工具参数见系统提示；流程见 `docs_get`（`authoring-workflow` 等）"
    },
    "help.ref": {
      "cli": "`qkrpc help --json`",
      "agent": "聊天工具列表（无需单独 help 工具）"
    },
    "connectivity.p0": {
      "cli": "连通问题看命令 stderr，或 `qkrpc serve` 后 `GET http://127.0.0.1:9477/health`",
      "agent": "页头绿点表示 RPC 状态；qkrpc 类工具失败时检查 Quicker + 插件或 `qkrpc serve`"
    },
    "errors.source": {
