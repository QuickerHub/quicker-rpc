      "agent": "工具"
    },
    "patch.stdin.hint": {
      "cli": "Patch stdin：`Get-Content patch.json -Raw | qkrpc action patch --id <guid> --patch-file - --json`",
      "agent": ""
    },
    "subprogram.product": {
