      "agent": "全局库：**`qkrpc_subprogram_*` 工具**"
    },
    "action-icons.help": {
      "cli": "命令与开关见 `qkrpc help --json`",
      "agent": "搜图标：**`qkrpc_fa_search`**。"
    },
