  "ops": {
    "help": {
      "cli": "qkrpc help --json",
      "agent": null
    },
    "docs.get": {
      "cli": "qkrpc guide get --topic {{topic}} --json",
      "agent": "docs_get({ topic: \"{{topic}}\" })",
      "defaults": { "topic": "overview" }
    },
    "docs.search": {
      "cli": "qkrpc guide search --query {{query}} --json",
      "agent": "docs_search({ query: \"{{query}}\" })",
      "defaults": { "query": "keyword" }
    },
    "docs.index": {
      "cli": "qkrpc guide search [--limit 50] --json",
      "agent": "docs_index()"
    },
    "action.create": {
      "cli": "qkrpc action create --title \"{{title}}\" [--icon {{icon}}] --json",
      "agent": "qkrpc_action_create({ title: \"{{title}}\", icon?: \"{{icon}}\" })",
      "defaults": { "title": "动作名", "icon": "fa:Light_*" }
    },
    "action.list": {
      "cli": "qkrpc action list --query \"{{query}}\" [--scope {{scope}}] --json",
      "agent": "qkrpc_action_list({ query: \"{{query}}\", scope?: \"{{scope}}\" })",
      "defaults": { "query": "名", "scope": "agent" }
    },
    "action.search": {
      "cli": "qkrpc action search --query \"{{query}}\" [--scope {{scope}}] --json",
      "agent": "qkrpc_action_search({ query: \"{{query}}\", scope?: \"{{scope}}\" })",
      "defaults": { "query": "名", "scope": "agent" }
    },
    "action.get.structure": {
      "cli": "qkrpc action get --id {{id}} --return-mode structure --json",
      "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"structure\" })",
      "defaults": { "id": "<guid>" }
    },
    "action.get.full": {
      "cli": "qkrpc action get --id {{id}} --return-mode full --json",
      "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"full\" })",
      "defaults": { "id": "<guid>" }
    },
    "action.get.metadata": {
      "cli": "qkrpc action get --id {{id}} --return-mode metadata --json",
      "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"metadata\" })",
      "defaults": { "id": "<guid>" }
    },
    "action.set-metadata": {
      "cli": "qkrpc action set-metadata --id {{id}} --icon {{icon}} --expected-edit-version {{N}} --json",
      "agent": "qkrpc_action_set_metadata({ id: \"{{id}}\", icon: \"{{icon}}\", expectedEditVersion: {{N}} })",
      "defaults": { "id": "<guid>", "icon": "fa:Light_<Name>", "N": "<N>" }
    },
    "action.patch": {
      "cli": "qkrpc action patch --id {{id}} --patch-file patch.json --expected-edit-version {{N}} --json",
      "agent": "qkrpc_action_patch({ id: \"{{id}}\", patch: { ... }, expectedEditVersion: {{N}} })",
      "defaults": { "id": "<guid>", "N": "<N>" }
    },
    "action.patch.stdin": {
      "cli": "Get-Content patch.json -Raw | qkrpc action patch --id {{id}} --patch-file - --json",
      "agent": null,
      "defaults": { "id": "<guid>" }
    },
    "action.export": {
      "cli": "qkrpc action export --id {{id}} --dir {{dir}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无 export 工具；终端用 qkrpc CLI）",
      "defaults": { "id": "<guid>", "dir": ".quicker/actions/my-action" }
    },
    "action.import": {
      "cli": "qkrpc action import --dir {{dir}} [--expected-edit-version {{N}}] [--force] --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无 import 工具；终端用 qkrpc CLI）",
      "defaults": { "dir": ".quicker/actions/my-action", "N": "N" }
    },
    "subprogram.create": {
      "cli": "qkrpc subprogram create --name \"{{name}}\" [--icon {{icon}}] --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无 subprogram create；终端用 qkrpc CLI）",
      "defaults": { "name": "名", "icon": "fa:Light_*" }
    },
    "subprogram.get": {
      "cli": "qkrpc subprogram get --id {{id}} --return-mode full --json",
      "agent": "qkrpc_subprogram_get({ id: \"{{id}}\", returnMode: \"full\" })",
      "defaults": { "id": "<id|name>" }
    },
    "subprogram.patch": {
      "cli": "qkrpc subprogram patch --id {{id}} --patch-file patch.json --expected-edit-version {{N}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无 subprogram patch；终端用 qkrpc CLI）",
      "defaults": { "id": "<id>", "N": "<N>" }
    },
    "subprogram.export": {
      "cli": "qkrpc subprogram export --id {{id}} --dir {{dir}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无；终端用 qkrpc CLI）",
      "defaults": { "id": "<nameOrId>", "dir": ".quicker/subprograms/my-sub" }
    },
    "subprogram.import": {
      "cli": "qkrpc subprogram import --dir {{dir}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无；终端用 qkrpc CLI）",
      "defaults": { "dir": ".quicker/subprograms/my-sub" }
    },
    "step-runner.search": {
      "cli": "qkrpc step-runner search --query \"{{query}}\" --json",
      "agent": "qkrpc_step_runner_search({ query: \"{{query}}\" })",
      "defaults": { "query": "剪贴板|clipboard|sys:*clip*" }
    },
    "step-runner.search.expr": {
      "cli": "qkrpc step-runner search --query \"表达式|evalexpression\" --json",
      "agent": "qkrpc_step_runner_search({ query: \"表达式|evalexpression\" })"
    },
    "step-runner.get": {
      "cli": "qkrpc step-runner get --key {{key}} --json",
      "agent": "qkrpc_step_runner_get({ key: \"{{key}}\" })",
      "defaults": { "key": "sys:MsgBox" }
    },
    "step-runner.get.control": {
      "cli": "qkrpc step-runner get --key {{key}} --control-field {{control}} --json",
      "agent": "qkrpc_step_runner_get({ key: \"{{key}}\", controlField: \"{{control}}\" })",
      "defaults": { "key": "sys:windowOperations", "control": "move_ex" }
    },
    "step-runner.get.subprogram": {
      "cli": "qkrpc step-runner get --key sys:subprogram --json",
      "agent": "qkrpc_step_runner_get({ key: \"sys:subprogram\" })"
    },
    "step-runner.get.evalexpression": {
      "cli": "qkrpc step-runner get --key sys:evalexpression --json",
      "agent": "qkrpc_step_runner_get({ key: \"sys:evalexpression\" })"
    },
    "fa.search": {
      "cli": "qkrpc fa search [--query {{query}}] --json",
      "agent": "qkrpc_fa_search({ query?: \"{{query}}\" })",
      "defaults": { "query": "keyword" }
    }
  }
}
