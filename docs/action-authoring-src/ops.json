      "cli": "",
      "agent": ""
    },
    "overview.pipeline.header": {
      "cli": "命令 / 主题",
      "agent": "工具 / 主题"
    },
    "overview.workflow.when": {
      "cli": "执行 P1–P7 的命令与示例",
      "agent": "执行 P1–P7 的工具与示例"
    }
  },
  "topics": {
    "overview": {
      "description": "Quicker 动作无头编辑总览与 P0–P7 专题索引。Use when starting action editing or choosing which guide topic to read next.",
      "compatibility": "QuickerAgent (agent-ui); requires Quicker + QuickerRpc plugin"
    },
    "authoring-workflow": {
      "description": "Quicker 动作编辑 P1–P7 主流程。Use before the first action edit in a session.",
      "allowed-tools": "qkrpc_action_create qkrpc_action_list qkrpc_action_search qkrpc_action_get qkrpc_action_patch qkrpc_action_set_metadata qkrpc_step_runner_get qkrpc_step_runner_search workspace_action_projects workspace_action_read_data workspace_action_write_data workspace_action_edit_data workspace_file_read workspace_file_write workspace_file_edit",
      "metadata": { "phase": "P1-P7" }
    },
    "workspace-editing": {
      "description": ".quicker/actions/{actionId} 工作区布局、workspace_* 工具分工、file 外置与 qkrpc_action_patch 保存。Use when editing data.json or files/ on disk in agent-ui.",
      "allowed-tools": "qkrpc_action_get qkrpc_action_patch workspace_action_projects workspace_action_read_data workspace_action_write_data workspace_action_edit_data workspace_file_read workspace_file_write workspace_file_edit",
      "compatibility": "QuickerAgent; requires working directory in sidebar"
    },
    "variables": {
      "description": "data.json 中 variables[] 的类型、defaultValue、varKey/outputParams 绑定；quicker_in_param 边界。Use when editing action variables.",
      "allowed-tools": "workspace_action_read_data workspace_action_write_data workspace_action_edit_data qkrpc_step_runner_get",
      "metadata": { "phase": "P2-P6" }
    },
    "cli-setup": {
      "description": "QuickerAgent 环境前置与 docs_get/docs_search/docs_index 用法。Use when setting up agent-ui or explaining how to read local authoring guides.",
      "allowed-tools": "docs_get docs_search docs_index"
    },
    "patch-workflow": {
      "description": "CLI 内联 action patch JSON 形状（qkrpc action patch --patch-file）。",
      "profiles": ["cli"],
      "metadata": { "phase": "P6" }
    },
    "step-modules": {
      "description": "常用 stepRunnerKey 速查表。Use before step-runner search when a known module might fit.",
      "allowed-tools": "qkrpc_step_runner_get qkrpc_step_runner_search",
      "metadata": { "phase": "P5" }
    },
    "step-runner-search": {
      "description": "step-runner 目录搜索语法（OR、通配、sys:*）。Use when finding a step module key before qkrpc_step_runner_get.",
      "allowed-tools": "qkrpc_step_runner_search qkrpc_step_runner_get",
      "metadata": { "phase": "P5" }
    },
    "implementation-fallback": {
      "description": "P4 回退选型：须先排除 expressions/evalexpression，再考虑 sys:csscript vs runScript。Use when no dedicated step module fits after checking expressions.",
      "allowed-tools": "qkrpc_step_runner_search qkrpc_step_runner_get qkrpc_action_patch",
      "metadata": { "phase": "P4" }
    },
    "expressions": {
      "description": "P4 首选：$=、$$ 与 sys:evalexpression（LINQ/字符串/JSON/多变量赋值）。Prefer before sys:csscript for data transforms.",
      "allowed-tools": "qkrpc_step_runner_get workspace_action_edit_data workspace_action_write_data qkrpc_action_patch",
      "metadata": { "phase": "P4" }
    },
    "subprogram-workflow": {
      "description": "公共子程序与动作内子程序的区别及调用工作流。Use when adding subprogram call steps or editing subprogram projects.",
      "allowed-tools": "qkrpc_subprogram_search qkrpc_subprogram_get qkrpc_step_runner_get qkrpc_action_patch",
      "metadata": { "phase": "P5-P6" }
    },
    "action-project-files": {
      "description": "CLI：qkrpc action extract/apply 与 .quicker/actions/{actionId} 目录。",
      "profiles": ["cli"]
    }
  },
  "ops": {
    "help": {
      "cli": "qkrpc help --json",
      "agent": null
    },
    "docs.get": {
      "cli": "qkrpc guide get --topic {{topic}} --json",
      "agent": "docs_get({ topic: \"{{topic}}\" })",
      "defaults": { "topic": "overview" }
    },
    "docs.search": {
      "cli": "qkrpc guide search --query {{query}} --json",
      "agent": "docs_search({ query: \"{{query}}\" })",
      "defaults": { "query": "keyword" }
    },
    "docs.index": {
      "cli": "qkrpc guide search [--limit 50] --json",
      "agent": "docs_index()"
    },
    "action.create": {
      "cli": "qkrpc action create --title \"{{title}}\" [--icon {{icon}}] --json",
      "agent": "qkrpc_action_create({ title: \"{{title}}\", icon?: \"{{icon}}\" })",
      "defaults": { "title": "动作名", "icon": "fa:Light_*" }
    },
    "action.list": {
      "cli": "qkrpc action list --query \"{{query}}\" [--scope {{scope}}] --json",
      "agent": "qkrpc_action_list({ query: \"{{query}}\", scope?: \"{{scope}}\" })",
      "defaults": { "query": "名", "scope": "agent" }
    },
    "action.search": {
      "cli": "qkrpc action search --query \"{{query}}\" [--scope {{scope}}] --json",
      "agent": "qkrpc_action_search({ query: \"{{query}}\", scope?: \"{{scope}}\" })",
      "defaults": { "query": "名", "scope": "agent" }
    },
    "action.get.structure": {
      "cli": "qkrpc action get --id {{id}} --return-mode structure --json",
      "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"structure\" })",
      "defaults": { "id": "<guid>" }
    },
    "action.get.full": {
      "cli": "qkrpc action get --id {{id}} --return-mode full --json",
      "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"full\" })",
      "defaults": { "id": "<guid>" }
    },
    "action.get.metadata": {
      "cli": "qkrpc action get --id {{id}} --return-mode metadata --json",
      "agent": "qkrpc_action_get({ id: \"{{id}}\", returnMode: \"metadata\" })",
      "defaults": { "id": "<guid>" }
    },
    "action.set-metadata": {
      "cli": "qkrpc action set-metadata --id {{id}} --icon {{icon}} --expected-edit-version {{N}} --json",
      "agent": "qkrpc_action_set_metadata({ id: \"{{id}}\", icon: \"{{icon}}\", expectedEditVersion: {{N}} })",
      "defaults": { "id": "<guid>", "icon": "fa:Light_<Name>", "N": "<N>" }
    },
    "action.patch": {
      "cli": "qkrpc action patch --id {{id}} --patch-file patch.json --expected-edit-version {{N}} --json",
      "agent": "qkrpc_action_patch({ id: \"{{id}}\" })",
      "agentNote": "（从 .quicker 项目 apply；勿传 patch 对象。可选 expectedEditVersion / force — 见工具说明。）",
      "defaults": { "id": "<guid>", "N": "<N>" }
    },
    "action.patch.stdin": {
      "cli": "Get-Content patch.json -Raw | qkrpc action patch --id {{id}} --patch-file - --json",
      "agent": null,
      "defaults": { "id": "<guid>" }
    },
    "action.export": {
      "cli": "qkrpc action export --id {{id}} --dir {{dir}} --json",
      "agent": "qkrpc_action_export({ id: \"{{id}}\", dir: \"{{dir}}\" })",
      "agentNote": "（legacy；优先 qkrpc_action_extract）",
      "defaults": { "id": "<guid>", "dir": ".quicker/actions/<guid>" }
    },
    "action.extract": {
      "cli": "qkrpc action extract --id {{id}} [--dir {{dir}}] [--min-lines 10] --json",
      "agent": null,
      "agentNote": "（agent-gui 内部：qkrpc_action_get 自动 extract，勿手动调用）",
      "defaults": { "id": "<guid>", "dir": ".quicker/actions/<guid>" }
    },
    "action.apply": {
      "cli": "qkrpc action apply --id {{id}} [--dir {{dir}}] [--expected-edit-version {{N}}] [--force] --json",
      "agent": null,
      "agentNote": "（agent-gui 内部：qkrpc_action_patch 自动 apply，勿手动调用）",
      "defaults": { "id": "<guid>", "dir": ".quicker/actions/<guid>", "N": "<N>" }
    },
    "action.validate": {
      "cli": "qkrpc action validate [--id {{id}}] [--dir {{dir}}] --json",
      "agentNote": "由 qkrpc_action_apply 内部调用；无需 agent 单独执行",
      "defaults": { "id": "<guid>", "dir": ".quicker/actions/<guid>" }
    },
    "action.import": {
      "cli": "qkrpc action import --dir {{dir}} [--expected-edit-version {{N}}] [--force] --json",
      "agent": "qkrpc_action_import({ dir: \"{{dir}}\", expectedEditVersion: {{N}} })",
      "agentNote": "（legacy；优先 qkrpc_action_apply）",
      "defaults": { "dir": ".quicker/actions/<guid>", "N": "N" }
    },
    "subprogram.create": {
      "cli": "qkrpc subprogram create --name \"{{name}}\" [--icon {{icon}}] --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无 subprogram create；终端用 qkrpc CLI）",
      "defaults": { "name": "名", "icon": "fa:Light_*" }
    },
    "subprogram.get": {
      "cli": "qkrpc subprogram get --id {{id}} --return-mode full --json",
      "agent": "qkrpc_subprogram_get({ id: \"{{id}}\", returnMode: \"full\" })",
      "defaults": { "id": "<id|name>" }
    },
    "subprogram.patch": {
      "cli": "qkrpc subprogram patch --id {{id}} --patch-file patch.json --expected-edit-version {{N}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无 subprogram patch；终端用 qkrpc CLI）",
      "defaults": { "id": "<id>", "N": "<N>" }
    },
    "subprogram.export": {
      "cli": "qkrpc subprogram export --id {{id}} --dir {{dir}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无；终端用 qkrpc CLI）",
      "defaults": { "id": "<nameOrId>", "dir": ".quicker/subprograms/my-sub" }
    },
    "subprogram.import": {
      "cli": "qkrpc subprogram import --dir {{dir}} --json",
      "agent": null,
      "agentNote": "（agent-ui 暂无；终端用 qkrpc CLI）",
      "defaults": { "dir": ".quicker/subprograms/my-sub" }
    },
    "step-runner.search": {
      "cli": "qkrpc step-runner search --query \"{{query}}\" --json",
      "agent": "qkrpc_step_runner_search({ query: \"{{query}}\" })",
      "defaults": { "query": "剪贴板|clipboard|sys:*clip*" }
    },
    "step-runner.search.expr": {
      "cli": "qkrpc step-runner search --query \"表达式|evalexpression\" --json",
      "agent": "qkrpc_step_runner_search({ query: \"表达式|evalexpression\" })"
    },
    "step-runner.get": {
      "cli": "qkrpc step-runner get --key {{key}} --json",
      "agent": "qkrpc_step_runner_get({ key: \"{{key}}\" })",
      "defaults": { "key": "sys:MsgBox" }
    },
    "step-runner.get.control": {
      "cli": "qkrpc step-runner get --key {{key}} --control-field {{control}} --json",
      "agent": "qkrpc_step_runner_get({ key: \"{{key}}\", controlField: \"{{control}}\" })",
      "defaults": { "key": "sys:windowOperations", "control": "move_ex" }
    },
    "step-runner.get.subprogram": {
      "cli": "qkrpc step-runner get --key sys:subprogram --json",
      "agent": "qkrpc_step_runner_get({ key: \"sys:subprogram\" })"
    },
    "step-runner.get.evalexpression": {
      "cli": "qkrpc step-runner get --key sys:evalexpression --json",
      "agent": "qkrpc_step_runner_get({ key: \"sys:evalexpression\" })"
    },
    "fa.search": {
      "cli": "qkrpc fa search [--query {{query}}] --json",
      "agent": "qkrpc_fa_search({ query?: \"{{query}}\" })",
      "defaults": { "query": "keyword" }
    }
  }
}
