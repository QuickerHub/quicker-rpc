    },
    "step-runner.get.invoke": {
      "cli": "**`step-runner get`**",
      "agent": "**`qkrpc_step_runner_get`**"
    },
    "step-runner.search.invoke": {
      "cli": "**`step-runner search`**",
      "agent": "**`qkrpc_step_runner_search`**"
    },
    "cli-setup.intro": {
      "cli": "Quicker 运行中且已加载 QuickerRpc 插件。高频调用可先 `qkrpc serve`（默认 `http://127.0.0.1:9477`）。",
      "agent": "Quicker 运行中且已加载 QuickerRpc 插件。推荐 `qkrpc serve`（agent-ui 优先 HTTP）。文档用 **`docs_get` / `docs_search` / `docs_index`** 本地工具，不经 qkrpc。"
    },
    "cli-setup.title": {
      "cli": "CLI setup for agents",
      "agent": "Agent setup（agent-ui）"
    },
    "cli-setup.agent.p0": {
      "cli": "",
      "agent": "按需读文档（系统提示已含核心规则，勿在会话开头连续 `docs_get` 多篇全文）：\n\n| 工具 | 用途 |\n|------|------|\n| `docs_index` | 列出全部主题 id |\n| `docs_get` | `topic`: 如 `overview`、`authoring-workflow` |\n| `docs_search` | `query`: 关键词检索主题 |"
    },
    "patch.invoke": {
      "cli": "**`action patch`**",
      "agent": "**`qkrpc_action_patch`**"
    },
    "patch.set-metadata.alt": {
      "cli": "**`action set-metadata`**",
      "agent": "**`qkrpc_action_set_metadata`**"
    },
    "edit-version.next": {
      "cli": "下次 `--expected-edit-version`",
      "agent": "下次 `expectedEditVersion`"
    },
    "edit-version.field": {
      "cli": "`--expected-edit-version`",
      "agent": "`expectedEditVersion`"
    },
    "control-field.get": {
      "cli": "**`--control-field <value>`**",
      "agent": "**`controlField`**"
    },
    "action.get.retry": {
      "cli": "`action get`",
      "agent": "`qkrpc_action_get`"
    },
    "subprogram.call.chain": {
      "cli": "→ `step-runner get --key sys:subprogram`\n→ `action patch` 添加步骤，`inputParams.subProgram.value = callIdentifier`",
      "agent": "→ `qkrpc_step_runner_get({ key: \"sys:subprogram\" })`\n→ `workspace_action_edit_data` 写入 `data.json` 步骤（`inputParams.subProgram.value = callIdentifier`）\n→ `qkrpc_action_patch({ id })`"
    },
