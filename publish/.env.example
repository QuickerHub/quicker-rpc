# Bitiful S3 credentials for local QuickerAgent upload (publish/Upload-QuickerAgentToBitiful.ps1).
# Copy to publish/.env — gitignored.
#
# BITIFUL_UPLOAD_IN_CI=false in GitHub repo vars (default): CI skips upload; maintainer uploads locally.
# Set BITIFUL_UPLOAD_IN_CI=true only if you want the overseas GitHub runner to upload (slow).

BITIFUL_ACCESS_KEY=
BITIFUL_SECRET_KEY=
BITIFUL_BUCKET_NAME=quicker-pkgs
BITIFUL_ENDPOINT_URL=https://s3.bitiful.net
BITIFUL_OBJECT_PREFIX=quicker-rpc/quicker-agent

# XOR pepper for encrypted llm-publish.config.json (never commit real value).
# Set ONCE; must match GitHub publish env LLM_REMOTE_PUBLISH_CIPHER_PEPPER — do NOT rotate
# (rotating breaks OSS decrypt for already-installed QuickerAgent).
# One-time sync: pwsh ./publish/Sync-LlmRemoteCipherPepper.ps1
LLM_REMOTE_PUBLISH_CIPHER_PEPPER=

# Optional: voice-asr plugin zips (Upload-VoiceAsrToBitiful.ps1)
# BITIFUL_VOICE_ASR_OBJECT_PREFIX=quicker-rpc/voice-asr

# Tauri official updater signing (Publish-QuickerAgent.ps1 / CI)
# Generate locally: pnpm exec tauri signer generate -w publish/.tauri/quicker-agent.key -f --ci
# TAURI_SIGNING_PRIVATE_KEY_PATH=publish/.tauri/quicker-agent.key
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Private submodule checkout in release-cli build-cli (QuickerOrg/Quicker.ActionRuntime).
# Fine-grained PAT: Contents read on that repo only. Sync: pwsh ./publish/Sync-ActionRuntimeSubmodulePat.ps1
ACTIONRUNTIME_SUBMODULE_PAT=
