# Bitiful S3 credentials for local QuickerAgent upload (publish/Upload-QuickerAgentToBitiful.ps1).
# Copy to publish/.env — gitignored.
#
# BITIFUL_UPLOAD_IN_CI=false in GitHub repo vars (default): CI skips upload; maintainer uploads locally.
# Set BITIFUL_UPLOAD_IN_CI=true only if you want the overseas GitHub runner to upload (slow).

BITIFUL_ACCESS_KEY=
BITIFUL_SECRET_KEY=
BITIFUL_BUCKET_NAME=quicker-pkgs
BITIFUL_ENDPOINT_URL=https://s3.bitiful.net
BITIFUL_OBJECT_PREFIX=quicker-rpc/quicker-agent
